# PostgreSQL connection (Neon, Render, Vercel Postgres, or local)
# Render free-tier databases sleep when idle; add connect_timeout so the first
# request can wait for the database to wake up.
# Prefer a pooled connection string in production (Neon pooler, Supabase pooler, PgBouncer).
DATABASE_URL="postgresql://user:password@host:5432/americano?sslmode=require&connect_timeout=30"
