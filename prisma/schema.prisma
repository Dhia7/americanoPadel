generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum ScoringMode {
  FIXED
  TIMED
}

model Tournament {
  id                String           @id @default(cuid())
  name              String
  status            TournamentStatus @default(DRAFT)
  scoringMode       ScoringMode
  pointsPerMatch    Int              @default(24)
  durationMinutes   Int?
  totalRounds       Int
  courtCount        Int              @default(1)
  pinHash           String?
  autoAdvanceRounds Boolean          @default(true)
  currentRound      Int              @default(0)
  createdAt         DateTime         @default(now())
  players           Player[]
  rounds            Round[]
}

model Player {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  sortOrder    Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchAsP1    Match[]    @relation("Player1")
  matchAsP2    Match[]    @relation("Player2")
  matchAsP3    Match[]    @relation("Player3")
  matchAsP4    Match[]    @relation("Player4")

  @@index([tournamentId])
}

model Round {
  id           String     @id @default(cuid())
  tournamentId String
  number       Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@unique([tournamentId, number])
}

model Match {
  id          String    @id @default(cuid())
  roundId     String
  court       Int       @default(1)
  player1Id   String
  player2Id   String
  player3Id   String
  player4Id   String
  teamAPoints Int?
  teamBPoints Int?
  completedAt DateTime?
  round       Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player1     Player    @relation("Player1", fields: [player1Id], references: [id])
  player2     Player    @relation("Player2", fields: [player2Id], references: [id])
  player3     Player    @relation("Player3", fields: [player3Id], references: [id])
  player4     Player    @relation("Player4", fields: [player4Id], references: [id])

  @@index([roundId])
}
